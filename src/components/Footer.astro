---
const year = new Date().getFullYear();
---

<footer class="bg-jhedai-primary text-white border-t border-white/5">
  <div class="container py-20">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="-mt-4">
        <a href="https://jhedai.com" class="flex items-center gap-2.5 inline-block">
          <img src="/logo-jhedai.png" alt="JhedAI" class="h-32 w-auto brightness-0 invert" />
        </a>
        <p class="text-[14px] text-white/80 leading-relaxed max-w-xs mt-3">
          Consultora de inteligencia artificial aplicada a la industria y
          gobierno en Chile. Metodología propietaria con enfoque en resultados medibles.
        </p>
      </div>

      <div>
        <p class="text-[14px] font-bold text-white mb-6 uppercase tracking-wider">Ecosistema</p>
        <ul class="space-y-4 text-[14px] text-white/80">
          <li><a href="https://jhedai.com/ecosistema" class="hover:text-jhedai-secondary transition-colors">Agentes Autónomos</a></li>
          <li><a href="https://jhedai.com/ecosistema" class="hover:text-jhedai-secondary transition-colors">Visión Industrial</a></li>
          <li><a href="https://jhedai.com/ecosistema" class="hover:text-jhedai-secondary transition-colors">Academia JhedAI</a></li>
          <li><a href="https://jhedai.com/ecosistema" class="hover:text-jhedai-secondary transition-colors">DeepLab</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[14px] font-bold text-white mb-6 uppercase tracking-wider">Compañía</p>
        <ul class="space-y-4 text-[14px] text-white/80">
          <li><a href="https://jhedai.com/#methodology" class="hover:text-jhedai-secondary transition-colors">Metodología</a></li>
          <li><a href="https://jhedai.com/#services" class="hover:text-jhedai-secondary transition-colors">Servicios</a></li>
          <li><a href="https://jhedai.com/#nosotros" class="hover:text-jhedai-secondary transition-colors">Nosotros</a></li>
          <li><a href="/blog" class="hover:text-jhedai-secondary transition-colors">Blog</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[14px] font-bold text-white mb-6 uppercase tracking-wider">Legal</p>
        <ul class="space-y-4 text-[14px] text-white/80">
          <li><a href="https://jhedai.com/privacidad" class="hover:text-jhedai-secondary transition-colors">Privacidad</a></li>
          <li><a href="https://jhedai.com/terminos" class="hover:text-jhedai-secondary transition-colors">Términos</a></li>
          <li><a href="https://jhedai.com/contacto" class="hover:text-jhedai-secondary transition-colors">Contacto</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6 text-[13px] text-white/70">
      <p>© {year} JhedAI. Todos los derechos reservados.</p>
      <div class="flex gap-8">
        <a href="https://www.linkedin.com/company/jhedai/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LinkedIn</a>
        <a href="https://www.instagram.com/jhedai_com/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Instagram</a>
        <a href="https://www.youtube.com/channel/UCtBghUFTLLCdpnbRDt9tFRA" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">YouTube</a>
      </div>
    </div>
  </div>
</footer>
