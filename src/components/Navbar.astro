---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + "/");

const navLinks = [
  { href: "/servicios", label: "Servicios" },
  { href: "/ecosistema", label: "Ecosistema" },
  { href: "/metodologia", label: "Metodología" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/blog", label: "Blog" },
];
---

<nav class="fixed top-0 left-0 right-0 z-[100] border-b border-jhedai-primary/10 bg-white/80 backdrop-blur-xl">
  <div class="container flex items-center justify-between h-16">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2.5 h-16 overflow-hidden">
        <picture>
          <source srcset="/logo-jhedai.webp" type="image/webp" />
          <img src="/logo-jhedai.png" alt="JhedAI" class="h-36 w-auto" width="256" height="256" />
        </picture>
      </a>

      <div class="hidden md:flex items-center gap-6 text-[14px] font-medium text-jhedai-primary/70">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "hover:text-jhedai-primary transition-colors",
              { "text-jhedai-primary font-semibold": isActive(href) }
            ]}
          >
            {label}
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center gap-4">
      <a href="/contacto" class="boton-principal nav-contactar-desktop">Contactar</a>
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg hover:bg-jhedai-primary/5 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="menu-bar block w-5 h-0.5 bg-jhedai-primary transition-all duration-300"></span>
        <span class="menu-bar block w-5 h-0.5 bg-jhedai-primary transition-all duration-300"></span>
        <span class="menu-bar block w-5 h-0.5 bg-jhedai-primary transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-jhedai-primary/10 bg-white/95 backdrop-blur-xl"
  >
    <div class="container py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "px-4 py-3 rounded-lg text-[15px] font-medium transition-colors",
            isActive(href)
              ? "bg-jhedai-primary/5 text-jhedai-primary font-semibold"
              : "text-jhedai-primary/70 hover:bg-jhedai-primary/5 hover:text-jhedai-primary"
          ]}
        >
          {label}
        </a>
      ))}
      <a href="/contacto" class="boton-principal text-center mt-3">Contactar</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bars = document.querySelectorAll(".menu-bar");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    // Animate hamburger → X
    if (isOpen) {
      bars[0]?.classList.add("rotate-45", "translate-y-2");
      bars[1]?.classList.add("opacity-0");
      bars[2]?.classList.add("-rotate-45", "-translate-y-2");
    } else {
      bars[0]?.classList.remove("rotate-45", "translate-y-2");
      bars[1]?.classList.remove("opacity-0");
      bars[2]?.classList.remove("-rotate-45", "-translate-y-2");
    }
  });

  // Close menu on link click
  menu?.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      bars[0]?.classList.remove("rotate-45", "translate-y-2");
      bars[1]?.classList.remove("opacity-0");
      bars[2]?.classList.remove("-rotate-45", "-translate-y-2");
    });
  });
</script>
