---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath.startsWith(path);
---

<nav class="fixed top-0 left-0 right-0 z-[100] border-b border-jhedai-primary/10 bg-white/80 backdrop-blur-xl">
  <div class="container flex items-center justify-between h-16">
    <div class="flex items-center gap-8">
      <a href="https://jhedai.com" class="flex items-center gap-2.5">
        <img src="/logo-jhedai.png" alt="JhedAI" class="h-36 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-6 text-[14px] font-medium text-jhedai-primary/70">
        <a href="https://jhedai.com/servicios" class="hover:text-jhedai-primary transition-colors">Servicios</a>
        <a href="https://jhedai.com/ecosistema" class="hover:text-jhedai-primary transition-colors">Ecosistema</a>
        <a href="https://jhedai.com/metodologia" class="hover:text-jhedai-primary transition-colors">Metodología</a>
        <a href="https://jhedai.com/nosotros" class="hover:text-jhedai-primary transition-colors">Nosotros</a>
        <a
          href="/blog"
          class:list={["hover:text-jhedai-primary transition-colors", { "text-jhedai-primary font-semibold": isActive("/blog") }]}
        >
          Blog
        </a>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <a href="https://jhedai.com/contacto" class="boton-principal inline-block">Contactar</a>
    </div>
  </div>
</nav>
