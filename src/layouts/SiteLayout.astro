---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  og?: {
    image?: string;
    type?: string;
    title?: string;
    description?: string;
  };
  noindex?: boolean;
  schemas?: object[];
}

const {
  title,
  description,
  canonical,
  og,
  noindex = false,
  schemas = [],
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to API and font origins -->
    <link rel="preconnect" href="https://jhedai-api.edison-985.workers.dev" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://jhedai-api.edison-985.workers.dev" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={og?.type || "website"} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={og?.title || title} />
    <meta property="og:description" content={og?.description || description} />
    <meta property="og:site_name" content="JhedAI" />
    <meta property="og:locale" content="es_CL" />
    {og?.image && <meta property="og:image" content={og.image} />}
    {og?.image && <meta property="og:image:width" content="1200" />}
    {og?.image && <meta property="og:image:height" content="630" />}
    {og?.image && <meta property="og:image:alt" content={og?.title || title} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@jhedai" />
    <meta name="twitter:title" content={og?.title || title} />
    <meta name="twitter:description" content={og?.description || description} />
    {og?.image && <meta name="twitter:image" content={og.image} />}

    <!-- GEO/AEO -->
    <meta name="geo.region" content="CL" />
    <meta name="geo.country" content="Chile" />

    <!-- Fonts (self-hosted) -->
    <link rel="preload" as="font" href="/fonts/montserrat-latin.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/opensans-latin.woff2" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <!-- JSON-LD schemas -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
