---
import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getPost, getRelatedPosts, getAllSlugs, getImageUrl } from "../../lib/api";

export async function getStaticPaths() {
  const slugs = await getAllSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };

const [post, related] = await Promise.all([
  getPost(slug),
  getRelatedPosts(slug),
]);

if (!post) {
  return Astro.redirect("/blog", 302);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);

const date = new Date(post.publishedAt).toLocaleDateString("es-CL", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const computedWordCount = post.content
  ? post.content.replace(/<[^>]+>/g, " ").split(/\s+/).filter(Boolean).length
  : 0;
const wordCount = post.wordCount || computedWordCount;

const categoryColors: Record<string, string> = {
  Industria: "bg-jhedai-primary/10 text-jhedai-primary",
  Regulación: "bg-jhedai-secondary/10 text-jhedai-secondary",
  Formación: "bg-jhedai-accent/10 text-jhedai-accent",
  Tendencias: "bg-emerald-500/10 text-emerald-600",
};
const catColor = categoryColors[post.category] || "bg-jhedai-primary/10 text-jhedai-primary";

const pageTitle = post.metaTitle || post.title;
const pageDescription = post.metaDescription || post.excerpt;
const canonical = post.canonicalUrl || `https://jhedai.com/blog/${slug}`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": post.schemaType || "BlogPosting",
  "@id": `https://jhedai.com/blog/${slug}#article`,
  url: `https://jhedai.com/blog/${slug}`,
  headline: post.title,
  description: post.primaryAnswer || post.metaDescription || post.excerpt,
  image: post.featuredImage ? { "@type": "ImageObject", url: post.featuredImage, caption: post.featuredImageAlt || post.title } : undefined,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  wordCount,
  abstract: post.excerpt,
  articleSection: post.category,
  inLanguage: "es-CL",
  isAccessibleForFree: true,
  about: [{ "@type": "Thing", name: post.category }],
  keywords: post.tags.join(", "),
  author: post.author.type === "Person"
    ? { "@type": "Person", name: post.author.name, jobTitle: post.author.jobTitle, url: post.author.url, sameAs: post.author.sameAs, ...(post.author.avatar ? { image: { "@type": "ImageObject", url: post.author.avatar } } : {}) }
    : { "@type": "Organization", name: post.author.name, url: post.author.url || "https://jhedai.com", "@id": "https://jhedai.com/#organization", sameAs: post.author.sameAs },
  publisher: {
    "@type": "Organization",
    name: "JhedAI",
    url: "https://jhedai.com",
    "@id": "https://jhedai.com/#organization",
    logo: { "@type": "ImageObject", url: "https://jhedai.com/logo-jhedai.png" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": `https://jhedai.com/blog/${slug}` },
  speakableSpecification: {
    "@type": "SpeakableSpecification",
    cssSelector: post.speakableSelectors?.length ? post.speakableSelectors : ["h1", ".article-intro", "h2"],
  },
};

const faqSchema = post.faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: post.faqItems.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
} : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://jhedai.com" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://jhedai.com/blog" },
    { "@type": "ListItem", position: 3, name: post.category, item: `https://jhedai.com/blog?category=${encodeURIComponent(post.category)}` },
    { "@type": "ListItem", position: 4, name: post.title, item: canonical },
  ],
};
---

<BlogLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  og={{ type: "article", image: post.ogImage || post.featuredImage, title: post.ogTitle || pageTitle, description: post.ogDescription || pageDescription }}
  twitter={{ title: post.twitterTitle, description: post.twitterDescription, image: post.ogImage || post.featuredImage }}
  publishedAt={post.publishedAt}
  updatedAt={post.updatedAt}
  author={post.author.name}
  category={post.category}
  tags={post.tags}
>
  <Fragment slot="head">
    {post.primaryAnswer && <meta name="primary-answer" content={post.primaryAnswer} />}
    {post.focusKeyword && <meta name="focus-keyword" content={post.focusKeyword} />}
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="pt-20 pb-24 bg-white">
    <div class="container" style="max-width: 48rem; margin-left: auto; margin-right: auto;">

      <!-- Breadcrumb -->
      <nav class="text-[13px] text-jhedai-primary/70 mb-6">
        <a href="https://jhedai.com" class="hover:text-jhedai-secondary transition-colors">Inicio</a>
        <span class="mx-2">&gt;</span>
        <a href="/blog" class="hover:text-jhedai-secondary transition-colors">Blog</a>
        <span class="mx-2">&gt;</span>
        <a href={`/blog?category=${encodeURIComponent(post.category)}`} class="hover:text-jhedai-secondary transition-colors">{post.category}</a>
        <span class="mx-2">&gt;</span>
        <span class="text-jhedai-primary/60">{post.title.length > 40 ? post.title.slice(0, 40) + "..." : post.title}</span>
      </nav>

      <!-- Meta info -->
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold ${catColor}`}>
          {post.category}
        </span>
        <time datetime={post.publishedAt} class="text-[13px] text-jhedai-primary/40">{date}</time>
        <span class="inline-flex items-center gap-1 text-[13px] text-jhedai-primary/40">
          {post.readTime} lectura
        </span>
      </div>

      <!-- Title -->
      <h1 class="text-3xl lg:text-4xl font-bold text-jhedai-primary leading-tight mb-8">
        {post.title}
      </h1>

      <!-- Key takeaways -->
      {post.keyTakeaways.length > 0 && (
        <div class="bg-jhedai-secondary/5 border border-jhedai-secondary/15 rounded-xl p-5 mb-8">
          <h2 class="text-sm font-bold text-jhedai-secondary uppercase tracking-wide mb-3">Puntos clave</h2>
          <ul class="space-y-2">
            {post.keyTakeaways.map((point) => (
              <li class="flex items-start gap-2 text-[15px] text-jhedai-primary/80">
                <span class="text-jhedai-secondary mt-0.5 shrink-0">&mdash;</span>
                {point}
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Featured image -->
      {post.featuredImage && (
        <div class="rounded-2xl overflow-hidden aspect-video mb-10 shadow-lg">
          <img
            src={getImageUrl(post.featuredImage, "featured")}
            alt={post.featuredImageAlt || post.title}
            loading="eager"
            fetchpriority="high"
            width="768"
            height="432"
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <!-- Primary answer (AEO speakable) -->
      {post.primaryAnswer && (
        <p class="article-intro text-lg text-jhedai-primary/80 leading-relaxed mb-6">
          {post.primaryAnswer}
        </p>
      )}

      <!-- Article content -->
      <div class="prose" set:html={post.content || ""} />

      <!-- FAQ -->
      {post.faqItems.length > 0 && (
        <section class="mt-10 space-y-3">
          <h2 class="text-xl font-bold text-jhedai-primary">Preguntas frecuentes</h2>
          {post.faqItems.map((faq) => (
            <details class="group border border-jhedai-neutral/15 rounded-xl">
              <summary class="cursor-pointer p-4 font-medium text-jhedai-primary group-open:text-jhedai-secondary transition-colors list-none flex items-center justify-between">
                {faq.question}
                <span class="text-jhedai-secondary ml-4 shrink-0 group-open:rotate-180 transition-transform">↓</span>
              </summary>
              <div class="px-4 pb-4 text-[15px] text-jhedai-primary/70 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </section>
      )}

      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="flex gap-2 flex-wrap mt-10">
          {post.tags.map((tag) => (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-jhedai-primary/5 text-jhedai-primary/60">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Divider -->
      <div class="h-px bg-jhedai-neutral/20 my-12"></div>

      <!-- CTA Block -->
      <div class="relative rounded-2xl overflow-hidden">
        <div class="absolute inset-0 bg-jhedai-primary"></div>
        <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-gradient-to-bl from-jhedai-secondary/20 to-transparent rounded-full blur-[80px]"></div>
        <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 30px 30px;"></div>
        <div class="relative z-10 p-10 lg:p-14 text-center">
          <h3 class="text-2xl font-bold text-white mb-3">¿Necesitas implementar IA en tu empresa?</h3>
          <p class="text-white/70 text-[16px] max-w-lg mx-auto mb-6 leading-relaxed">
            Agenda una consulta con nuestro equipo y descubre cómo la inteligencia artificial puede transformar tu operación.
          </p>
          <a
            href="https://jhedai.com/contacto"
            class="inline-flex items-center gap-2 bg-white text-jhedai-primary px-8 py-3.5 rounded-lg font-bold text-[16px] hover:brightness-110 transition-all shadow-xl"
          >
            Agendar consulta →
          </a>
        </div>
      </div>

      <!-- Related articles -->
      {related.length > 0 && (
        <>
          <div class="h-px bg-jhedai-neutral/20 my-12"></div>
          <div>
            <h3 class="text-xl font-bold text-jhedai-primary mb-8">También te puede interesar</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {related.slice(0, 3).map((p, i) => (
                <BlogCard post={p} index={i} />
              ))}
            </div>
          </div>
        </>
      )}

    </div>
  </div>
</BlogLayout>
