---
export const prerender = true;

import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getPosts, getCategories, getImageUrl } from "../../lib/api";

const [{ data: posts }, categories] = await Promise.all([
  getPosts(1, 100),
  getCategories(),
]);

const featuredPost = posts.find((p) => p.featured) || null;
const gridPosts = featuredPost ? posts.filter((p) => p.slug !== featuredPost.slug) : posts;
---

<BlogLayout
  title="Blog — Insights de IA Industrial | JhedAI"
  description="Artículos, análisis y casos de estudio sobre inteligencia artificial aplicada a la industria chilena."
  canonical="https://jhedai.com/blog"
>
  <Fragment slot="head">
    {featuredPost?.featuredImage && (
      <link rel="preload" as="image" href={getImageUrl(featuredPost.featuredImage, "featured")} fetchpriority="high" />
    )}
  </Fragment>
  <div class="pt-20 pb-24 bg-white">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="text-[13px] text-jhedai-primary/70 mb-6">
        <a href="https://jhedai.com" class="hover:text-jhedai-secondary transition-colors">Inicio</a>
        <span class="mx-2">&gt;</span>
        <span class="text-jhedai-primary/80">Blog</span>
      </nav>

      <!-- Header centrado igual al SPA -->
      <div class="text-center mb-12">
        <p class="text-[14px] text-[#3D6B8A] font-bold tracking-widest mb-4">BLOG</p>
        <h1 class="text-3xl lg:text-4xl font-bold text-jhedai-primary mb-4">
          Insights de IA Industrial
        </h1>
        <p class="text-[#3D6B8A] text-[16px] max-w-2xl mx-auto leading-relaxed">
          Artículos, análisis y casos de estudio sobre inteligencia artificial aplicada a la industria chilena.
        </p>
      </div>

      <!-- Category filters centrados -->
      <div class="flex flex-wrap justify-center gap-3 mb-12" id="category-filters">
        <button
          data-cat=""
          class="px-4 py-2 rounded-full text-[14px] font-medium transition-all bg-jhedai-primary text-white"
          onclick="filterCat(this, '')"
        >
          Todos
        </button>
        {categories.map((cat) => (
          <button
            data-cat={cat}
            class="px-4 py-2 rounded-full text-[14px] font-medium transition-all bg-jhedai-primary/5 text-[#3D6B8A] hover:bg-jhedai-primary/10"
            onclick={`filterCat(this, '${cat}')`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Featured post (solo página 1 sin filtro) -->
      {featuredPost && (
        <div class="mb-8">
          <a
            href={`/blog/${featuredPost.slug}`}
            class="group block relative rounded-2xl overflow-hidden"
          >
            <div class="grid lg:grid-cols-2 gap-0 glass-card overflow-hidden">
              <div class="aspect-video lg:aspect-auto lg:min-h-[320px] overflow-hidden">
                {featuredPost.featuredImage ? (
                  <img
                    src={getImageUrl(featuredPost.featuredImage, "featured")}
                    alt={featuredPost.featuredImageAlt || featuredPost.title}
                    loading="eager"
                    fetchpriority="high"
                    width="640"
                    height="360"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-jhedai-primary to-jhedai-secondary flex items-center justify-center">
                    <span class="text-8xl font-black text-white/10">J</span>
                  </div>
                )}
              </div>
              <div class="p-8 lg:p-12 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-4">
                  <span class="px-3 py-1 rounded-full text-xs font-bold bg-jhedai-secondary/10 text-jhedai-secondary">
                    {featuredPost.category}
                  </span>
                  <span class="text-[12px] text-[#3D6B8A]">
                    {new Date(featuredPost.publishedAt).toLocaleDateString("es-CL", { day: "numeric", month: "short", year: "numeric" })}
                  </span>
                </div>
                <h2 class="text-2xl lg:text-3xl font-black text-jhedai-primary mb-4 group-hover:text-jhedai-secondary transition-colors leading-tight">
                  {featuredPost.title}
                </h2>
                <p class="text-[#3D6B8A] leading-relaxed mb-6 line-clamp-3">
                  {featuredPost.excerpt}
                </p>
                <span class="inline-flex items-center gap-2 text-[14px] font-semibold text-jhedai-secondary">
                  Leer artículo →
                </span>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- Grid de cards -->
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
          {gridPosts.map((post, i) => (
            <div data-category={post.category}>
              <BlogCard post={post} index={i} />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-24 text-jhedai-primary/40">
          <p class="text-xl">No hay artículos en esta categoría aún.</p>
        </div>
      )}

    </div>
  </div>

  <script>
    function filterCat(btn: HTMLButtonElement, cat: string) {
      document.querySelectorAll('#category-filters button').forEach((b) => {
        (b as HTMLButtonElement).classList.remove('bg-jhedai-primary', 'text-white');
        (b as HTMLButtonElement).classList.add('bg-jhedai-primary/5', 'text-[#3D6B8A]');
      });
      btn.classList.add('bg-jhedai-primary', 'text-white');
      btn.classList.remove('bg-jhedai-primary/5', 'text-[#3D6B8A]');

      document.querySelectorAll<HTMLElement>('#posts-grid [data-category]').forEach((el) => {
        el.style.display = !cat || el.dataset.category === cat ? '' : 'none';
      });
    }
    (window as Window & { filterCat: typeof filterCat }).filterCat = filterCat;
  </script>
</BlogLayout>
